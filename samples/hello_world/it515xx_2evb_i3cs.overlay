&pinctrl {
	i3c2_clk_gpe2_default: i3c2_clk_gpe2_default {
		gpio-voltage = "1v8";
	};
	i3c2_data_gpe3_default: i3c2_data_gpe3_default {
		gpio-voltage = "1v8";
	};
	i3c3_clk_gpf0_default: i3c3_clk_gpf0_default {
		gpio-voltage = "1v8";
	};
	i3c3_data_gpf1_default: i3c3_data_gpf1_default {
		gpio-voltage = "1v8";
	};
};

&i3c2 {
	status = "okay";

	pinctrl-0 = <
		     &i3c2_clk_gpe2_default
		     &i3c2_data_gpe3_default>;
	pinctrl-names = "default";
	static-address = <0x21>;
	pid-random-value = <0x12345678>;
	bcr = <0xf>; // With ibi payload
	dcr = <0x1>;

	tgt_mqueue@21 {
		compatible = "ite,i3c-tgt-mqueue";
		reg = <0x21>;
		label = "tgt-mqueue";
		status = "okay";
	};
};

&i3c3 {
	status = "okay";

	pinctrl-0 = <
		     &i3c3_clk_gpf0_default
		     &i3c3_data_gpf1_default>;
	pinctrl-names = "default";
	static-address = <0x19>;
	// bcr = <0xb>; // Without ibi payload
	bcr = <0x9>; // ibi is not capable
	dcr = <0x2>;
};
