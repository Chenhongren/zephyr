config ITE_I3C_SAMPLE
	bool
	depends on DT_HAS_ITE_IT51XXX_I3CM_ENABLED || DT_HAS_ITE_IT51XXX_I3CS_ENABLED
	default y
	help
	  Enable the ite i3c sample driver, including tgt mqueue and ctrl dummy device.

if ITE_I3C_SAMPLE

config I3C_TGT_MQUEUE
	bool "I3C target message queue driver"
	depends on DT_HAS_ITE_I3C_TGT_MQUEUE_ENABLED
	default y

config I3C_CTRL_DUMMY
	bool "I3C controller dummy driver"
	depends on DT_HAS_ITE_I3C_CTRL_DUMMY_ENABLED
	default y

endif # ITE_I3C_SAMPLE